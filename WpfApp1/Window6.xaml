<Window x:Class="WpfApp1.Window6"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Личный кабинет"
        Height="500"
        Width="800"
        Background="#1E1E1E"
        >
    <Grid>
        <Grid x:Name="LoginGrid">
            <Border Width="300"
                    Height="250"
                    Background="Gray"
                    BorderBrush="Black"
                    BorderThickness="1">
                <StackPanel Margin="20">
                    <TextBlock Text="Вход"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="tbLogin" Background="DarkGray"/>
                    <TextBlock Text="Пароль"
                               Margin="0,10,0,0"/>
                    <PasswordBox x:Name="pbPassword" Background="DarkGray"/>
                    <Button Content="Войти"
                            Height="35"
                            Margin="0,20,0,0"
                            Click="Login_Click"
                            Background="LightGray"/>
                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="ProfileGrid"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Width="200"
                    Height="200"
                    Margin="20"
                    BorderBrush="Black"
                    BorderThickness="1">
                <Image x:Name="imgPhoto" Source="/images/user.png" Stretch="Uniform" Visibility="Hidden"/>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="20">
                <TextBlock Text="Личный кабинет"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>
                <TextBlock Text="ФИО" Width="100"/>
                <TextBox x:Name="tbFio"
                         IsReadOnly="True" Width="100"/>
                <TextBlock Text="Телефон"
                           Margin="0,10,0,0" Width="100"/>
                <TextBox x:Name="tbPhone"
                         IsReadOnly="True" Width="100"/>
                <TextBlock Text="Email"
                           Margin="0,10,0,0" Width="100"/>
                <TextBox x:Name="tbEmail"
                         IsReadOnly="True" Width="100"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,20,0,0">
                    <Button x:Name="btnEdit"
                            Content="Редактировать"
                            Width="150"
                            Click="Edit_Click"/>
                    <Button x:Name="btnSave"
                            Content="Сохранить"
                            Width="150"
                            Margin="10,0,0,0"
                            Visibility="Collapsed"
                            Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
