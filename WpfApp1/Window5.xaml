<Window x:Class="WpfApp1.Window5"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Каклькулятор"
        Height="450"
        Width="350"
        Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="Display"
                 Grid.Row="0"
                 Grid.ColumnSpan="4"
                 FontSize="28"
                 HorizontalContentAlignment="Right"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 Background="LightGray"/>
        <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="1" Grid.Column="3" Content="/" Click="Operation_Click" Background="Gray"/>
        <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="2" Grid.Column="3" Content="*" Click="Operation_Click" Background="Gray"/>
        <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="3" Grid.Column="3" Content="-" Click="Operation_Click" Background="Gray"/>
        <Button Grid.Row="4" Grid.Column="0" Content="0" Click="Number_Click" Background="Gray"/>
        <Button Grid.Row="4" Grid.Column="1" Content="C" Click="Clear_Click" Background="DarkOrange"/>
        <Button Grid.Row="4" Grid.Column="2" Content="=" Click="Equals_Click" Background="DarkGray"/>
        <Button Grid.Row="4" Grid.Column="3" Content="+" Click="Operation_Click" Background="Gray"/>
    </Grid>
</Window>
